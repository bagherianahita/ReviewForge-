# Copy to .env and adjust for local development.
# Never commit .env — it is listed in .gitignore.

# Optional: enables LLM peer-review summaries (demo works without this)
OPENAI_API_KEY=

# PostgreSQL (default matches docker-compose db service)
DATABASE_URL=postgresql+asyncpg://reviewforge:reviewforge@localhost:5432/reviewforge
SYNC_DATABASE_URL=postgresql://reviewforge:reviewforge@localhost:5432/reviewforge
